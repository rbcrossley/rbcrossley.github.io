---
import { link } from '../../lib/link';
import type { CollectionEntry } from 'astro:content';

interface Props {
  posts?: CollectionEntry<'blog'>[];
}

const { posts } = Astro.props;
---

<!-- Hero Section - Clean SaaS Style with Tailwind -->
<section class="relative overflow-hidden bg-gradient-to-br from-slate-900 via-[#0a1c35] to-[#05101f] py-24 lg:py-32">
  <!-- Animated background elements -->
  <div class="absolute inset-0 opacity-30">
    <div class="absolute -top-40 -right-40 w-80 h-80 bg-[#0F3D78] rounded-full mix-blend-multiply filter blur-3xl animate-pulse"></div>
    <div class="absolute -bottom-40 -left-40 w-80 h-80 bg-purple-500 rounded-full mix-blend-multiply filter blur-3xl animate-pulse delay-1000"></div>
  </div>
  
  <div class="relative max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Left Column - Content -->
      <div class="text-center lg:text-left">
        <div class="flex flex-wrap gap-3 justify-center lg:justify-start mb-6">
          <span class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm border border-white/20 rounded-full px-4 py-1.5 text-sm font-medium text-white">
            🎓 Dedicated to CS students
          </span>
          <span class="inline-flex items-center gap-2 bg-gradient-to-r from-amber-500 to-orange-500 rounded-full px-4 py-1.5 text-sm font-semibold text-white">
            ✨ New lessons weekly
          </span>
        </div>
        
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight text-white mb-6">
          Master computer science 
          <span class="bg-gradient-to-r from-[#DCE8FF] via-[#8FB6E8] to-[#1A5F9E] bg-clip-text text-transparent">
            with crystal clarity
          </span>
        </h1>
        
        <p class="text-lg text-slate-300 mb-8 max-w-2xl mx-auto lg:mx-0 leading-relaxed">
          Berojgar Engineer is your premium virtual classroom for practical, beginner-friendly explanations. 
          Explore structured lessons, visual notes, and expert articles that make complex concepts stick — for life.
        </p>
        
        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start mb-12">
          <a href={link('/courses')} class="inline-flex items-center justify-center gap-2 px-8 py-3.5 text-base font-semibold text-white bg-gradient-to-r from-[#0F3D78] to-[#1A5F9E] rounded-xl hover:from-[#0A2B52] hover:to-[#0F3D78] transition-all duration-200 transform hover:scale-105 shadow-lg hover:shadow-xl">
            Explore Courses
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
            </svg>
          </a>
          <a href={link('/blog')} class="inline-flex items-center justify-center gap-2 px-8 py-3.5 text-base font-semibold text-white border-2 border-white/30 rounded-xl hover:bg-white/10 backdrop-blur-sm transition-all duration-200">
            Read Blog
          </a>
        </div>
        
        <!-- Stats Grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 max-w-2xl mx-auto lg:mx-0">
          <div class="bg-white/5 backdrop-blur-sm rounded-2xl p-4 border border-white/10 hover:bg-white/10 transition-all duration-200 group">
            <div class="flex items-center gap-3 mb-2">
              <svg class="w-6 h-6 text-[#8FB6E8]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"></path>
              </svg>
              <strong class="text-white text-lg">Structured learning</strong>
            </div>
            <span class="text-slate-300 text-sm">Courses grouped by subject and topic depth.</span>
          </div>
          
          <div class="bg-white/5 backdrop-blur-sm rounded-2xl p-4 border border-white/10 hover:bg-white/10 transition-all duration-200">
            <div class="flex items-center gap-3 mb-2">
              <svg class="w-6 h-6 text-[#DCE8FF]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"></path>
              </svg>
              <strong class="text-white text-lg">Clear explanations</strong>
            </div>
            <span class="text-slate-300 text-sm">Designed for students who want concepts to click faster.</span>
          </div>
        </div>
      </div>
      
      <!-- Hero Illustration (moved to separate component) -->
      <slot name="illustration" />
    </div>
  </div>

  <style is:inline>
    .delay-1000 {
      animation-delay: 1s;
    }
  </style>
</section>

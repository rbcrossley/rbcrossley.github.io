---
import { getCollection, type CollectionEntry } from 'astro:content';
import { link } from '../../lib/link';

interface Props {
  posts?: CollectionEntry<'blog'>[];
}

const { posts: customPosts } = Astro.props;

let posts: CollectionEntry<'blog'>[] = customPosts || [];

if (!customPosts) {
  const allPosts = (await getCollection('blog')).sort(
    (a: CollectionEntry<'blog'>, b: CollectionEntry<'blog'>) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
  );
  posts = allPosts.slice(0, 3);
}

// Compute platform counts so UI reflects actual content
const allCourses = await getCollection('courses').catch(() => [] as CollectionEntry<'courses'>[]);
const allBlogs = await getCollection('blog').catch(() => [] as CollectionEntry<'blog'>[]);

const coursesCount = allCourses.length;
const blogsCount = allBlogs.length;
const learnersCount = 2500; // fallback / estimated; update manually if you track this elsewhere
---

<!-- Right Column - Premium Hero Illustration -->
<div class="relative">
  <!-- Floating background orbs -->
  <div class="absolute -top-20 -right-20 w-72 h-72 bg-blue-500 rounded-full mix-blend-multiply filter blur-3xl opacity-20 animate-pulse"></div>
  <div class="absolute -bottom-20 -left-20 w-72 h-72 bg-purple-500 rounded-full mix-blend-multiply filter blur-3xl opacity-20 animate-pulse delay-1000"></div>
  
  <!-- Main Card Container -->
  <div class="relative bg-gradient-to-br from-white/10 via-white/5 to-transparent backdrop-blur-xl rounded-3xl p-8 border border-white/20 shadow-2xl transform transition-all duration-500 hover:scale-105">
    
    <!-- Header with live indicator -->
    <div class="flex items-center justify-between mb-8">
      <div class="flex items-center gap-3">
        <div class="relative">
          <div class="absolute inset-0 bg-green-500 rounded-full animate-ping opacity-75"></div>
          <div class="relative w-3 h-3 bg-green-500 rounded-full"></div>
        </div>
        <span class="text-white font-medium">Berojgar Classroom</span>
      </div>
      <div class="flex items-center gap-2 bg-white/10 backdrop-blur-sm rounded-full px-3 py-1.5">
        <svg class="w-4 h-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
        </svg>
        <span class="text-white text-sm font-medium">4.8 ★ (280+ reviews)</span>
      </div>
    </div>

    <!-- Main 3D-like Illustration -->
    <div class="relative mb-8">
      <!-- Floating elements with animation -->
      <div class="absolute -top-8 -left-8 w-24 h-24 bg-gradient-to-br from-blue-400 to-blue-600 rounded-2xl rotate-12 animate-float shadow-2xl flex items-center justify-center">
        <span class="text-3xl">📊</span>
      </div>
      <div class="absolute top-20 -right-6 w-20 h-20 bg-gradient-to-br from-purple-400 to-purple-600 rounded-xl -rotate-6 animate-float-delay shadow-2xl flex items-center justify-center">
        <span class="text-2xl">⚙️</span>
      </div>
      <div class="absolute bottom-16 -left-4 w-20 h-20 bg-gradient-to-br from-green-400 to-green-600 rounded-xl rotate-12 animate-float-slow shadow-2xl flex items-center justify-center">
        <span class="text-2xl">🗄️</span>
      </div>
      
      <!-- Central Dashboard Card -->
      <div class="relative bg-white rounded-2xl shadow-2xl overflow-hidden transform transition-all duration-500 hover:shadow-3xl">
        <!-- Dashboard Header -->
        <div class="bg-gradient-to-r from-[#0F3D78] to-[#1A5F9E] px-6 py-4">
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2">
              <div class="w-3 h-3 bg-red-500 rounded-full"></div>
              <div class="w-3 h-3 bg-yellow-500 rounded-full"></div>
              <div class="w-3 h-3 bg-green-500 rounded-full"></div>
            </div>
            <span class="text-white/80 text-sm font-mono">berojgarengineer.com</span>
            <!-- <svg class="w-5 h-5 text-white/60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4"/>
            </svg> -->
          </div>
        </div>
        
        <!-- Dashboard Content -->
        <div class="p-6">
          <!-- Section Header -->
          <div class="mb-4">
            <h3 class="font-bold text-slate-900 text-sm mb-4">📚 Recent Articles</h3>
          </div>
          
          <!-- Blog Posts -->
          <div class="space-y-3">
            {posts.map((post, index) => (
              <a
                href={link(`/blog/${post.slug}`)}
                class="flex items-center gap-3 p-3 bg-slate-50 rounded-xl hover:bg-blue-50 hover:border-blue-200 transition-all cursor-pointer group border border-slate-200"
              >
                <div class="w-10 h-10 bg-gradient-to-br from-blue-500 to-blue-600 rounded-lg flex items-center justify-center text-white font-bold flex-shrink-0 group-hover:shadow-md transition-all">
                  {index === 0 ? '🔥' : index === 1 ? '⭐' : '💡'}
                </div>
                <div class="flex-1 min-w-0">
                  <div class="font-semibold text-slate-800 group-hover:text-blue-600 transition-colors text-sm line-clamp-1">
                    {post.data.title}
                  </div>
                  <div class="text-xs text-slate-500">
                    {new Date(post.data.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
                  </div>
                </div>
                <svg class="w-4 h-4 text-slate-400 group-hover:text-blue-600 group-hover:translate-x-0.5 transition-all flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </a>
            ))}
          </div>
          
          <!-- Quick Stats -->
            <div class="grid grid-cols-3 gap-3 mt-6 pt-4 border-t border-slate-200 max-w-xs">
              <div class="text-center">
                <div class="text-2xl font-bold text-slate-800">{coursesCount}</div>
                <div class="text-xs text-slate-500">Courses</div>
              </div>
              <div class="text-center">
                <div class="text-2xl font-bold text-slate-800">{blogsCount}</div>
                <div class="text-xs text-slate-500">Blogs</div>
              </div>
              <div class="text-center">
                <div class="text-2xl font-bold text-slate-800">{learnersCount.toLocaleString()}+</div>
                <div class="text-xs text-slate-500">Learners</div>
              </div>
            </div>
        </div>
      </div>
      
      <!-- Floating achievement badge -->
      <div class="absolute -bottom-4 -right-4 bg-gradient-to-r from-amber-400 to-orange-500 rounded-full p-3 shadow-2xl animate-bounce-slow">
        <div class="flex items-center gap-2 px-3 py-1">
          <span class="text-2xl">🏆</span>
          <div class="text-white">
            <div class="text-xs font-semibold">Top Rated</div>
            <div class="text-lg font-bold">#1 Platform</div>
          </div>
        </div>
      </div>
    </div>
    
    <!-- Bottom CTA -->
    <div class="flex items-center justify-between pt-4 border-t border-white/10">
      <div class="flex items-center gap-2">
        <div class="flex -space-x-2">
          <div class="w-8 h-8 rounded-full bg-gradient-to-br from-blue-400 to-blue-500 border-2 border-white flex items-center justify-center text-white text-xs font-bold">RB</div>
          <div class="w-8 h-8 rounded-full bg-gradient-to-br from-purple-400 to-purple-500 border-2 border-white flex items-center justify-center text-white text-xs font-bold">AK</div>
          <div class="w-8 h-8 rounded-full bg-gradient-to-br from-green-400 to-green-500 border-2 border-white flex items-center justify-center text-white text-xs font-bold">SJ</div>
          <div class="w-8 h-8 rounded-full bg-slate-700 border-2 border-white flex items-center justify-center text-white text-xs font-bold">+1k</div>
        </div>
        <span class="text-white/80 text-sm">{learnersCount}+ active learners</span>
      </div>
      <div class="flex items-center gap-2 text-white/80 text-sm">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
          <path d="M10 12a2 2 0 100-4 2 2 0 000 4z"/>
          <path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd"/>
        </svg>
        <span>Weekly updates</span>
      </div>
    </div>
  </div>
</div>

<style is:inline>
  @keyframes float {
    0%, 100% { transform: translateY(0px) rotate(12deg); }
    50% { transform: translateY(-20px) rotate(12deg); }
  }
  
  @keyframes float-delay {
    0%, 100% { transform: translateY(0px) rotate(-6deg); }
    50% { transform: translateY(-15px) rotate(-6deg); }
  }
  
  @keyframes float-slow {
    0%, 100% { transform: translateY(0px) rotate(12deg); }
    50% { transform: translateY(-10px) rotate(12deg); }
  }
  
  @keyframes slide {
    from { transform: translateX(-100%); }
    to { transform: translateX(0); }
  }
  
  @keyframes bounce-slow {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }
  
  .animate-float {
    animation: float 3s ease-in-out infinite;
  }
  
  .animate-float-delay {
    animation: float-delay 3.5s ease-in-out infinite;
  }
  
  .animate-float-slow {
    animation: float-slow 4s ease-in-out infinite;
  }
  
  .animate-slide {
    animation: slide 1s ease-out;
  }
  
  .animate-bounce-slow {
    animation: bounce-slow 2s ease-in-out infinite;
  }
  
  .delay-1000 {
    animation-delay: 1s;
  }
  
  @keyframes pulse {
    0%, 100% { opacity: 0.2; transform: scale(1); }
    50% { opacity: 0.3; transform: scale(1.1); }
  }
  
  .animate-pulse-slow {
    animation: pulse 4s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }
</style>

---
import { link } from '../../lib/link';

interface Props {
  title?: string;
  subtitle?: string;
}

const {
  title = "Everything you need to scale your learning",
  subtitle = "Join 5,000+ learners mastering computer science with structured lessons and clear explanations.",
} = Astro.props as Props;

---

<section class="relative overflow-hidden bg-gradient-to-br from-gray-50 via-white to-indigo-50 dark:from-gray-900 dark:via-gray-900 dark:to-indigo-950/30 py-24 lg:py-14">
  
  <!-- Modern grid background -->
  <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808012_1px,transparent_1px),linear-gradient(to_bottom,#80808012_1px,transparent_1px)] bg-[size:24px_24px]"></div>
  
  <!-- Decorative shapes removed for a clean banner -->

  <div class="relative max-w-7xl mx-auto px-6 lg:px-8">
    
    <!-- Header with SaaS badge -->
    <div class="text-center mb-16">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-[#0F3D78]/10 dark:bg-[#0A2B52]/30 text-[#0F3D78] dark:text-[#DCE8FF] text-sm font-medium mb-6">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-indigo-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-indigo-500"></span>
        </span>
        ⚡ Trusted by 5,000+ learners
      </div>
      
      <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold tracking-tight text-gray-900 dark:text-white mb-6">
        {title}
      </h1>
      <p class="text-xl text-gray-600 dark:text-gray-300 max-w-3xl mx-auto leading-relaxed">
        {subtitle}
      </p>
      
      <!-- CTA Buttons Group -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center mt-10">
        <a
          href={link('/courses')}
          class="group inline-flex items-center justify-center gap-2 px-8 py-4 text-lg font-semibold text-white bg-gradient-to-r from-[#0F3D78] to-[#1A5F9E] rounded-xl hover:from-[#0A2B52] hover:to-[#0F3D78] transition-all duration-200 transform hover:scale-105 shadow-lg hover:shadow-xl"
        >
          Start Learning
          <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
          </svg>
        </a>
        <a
          href={link('/blog')}
          class="inline-flex items-center justify-center gap-2 px-8 py-4 text-lg font-semibold text-gray-700 dark:text-gray-200 bg-white dark:bg-gray-800 border-2 border-gray-300 dark:border-gray-600 rounded-xl hover:border-indigo-500 dark:hover:border-indigo-400 transition-all duration-200"
        >
          Read our blog
        </a>
      </div>
    </div>
  </div>

</section>
</section>
---
import { getCollection, type CollectionEntry } from 'astro:content';
import Card from '../ui/Card.astro';
import Badge from '../ui/Badge.astro';

interface Props {
  posts?: CollectionEntry<'blog'>[];
  limit?: number;
  title?: string;
  subtitle?: string;
  showViewAll?: boolean;
}

const { 
  posts: customPosts, 
  limit = 3,
  title = "Latest from the Blog",
  subtitle = "Explore in-depth articles on computer science fundamentals, career growth, and industry insights.",
  showViewAll = true
} = Astro.props;

let posts: CollectionEntry<'blog'>[] = customPosts || [];

if (!customPosts) {
  const allPosts = (await getCollection('blog')).sort(
    (a: CollectionEntry<'blog'>, b: CollectionEntry<'blog'>) => 
      new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
  );
  posts = allPosts.slice(0, limit);
}

// Helper function to get fallback image based on category
const getFallbackImage = (category?: string) => {
  const fallbacks: Record<string, string> = {
    'Tutorial': 'https://images.unsplash.com/photo-1516116216624-53e697fedbea?w=800&h=400&fit=crop',
    'Career': 'https://images.unsplash.com/photo-1522071820081-009f0129c71c?w=800&h=400&fit=crop',
    'Industry': 'https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=800&h=400&fit=crop',
    'Review': 'https://images.unsplash.com/photo-1532619187608-e5375cab36aa?w=800&h=400&fit=crop'
  };
  return fallbacks[category || ''] || 'https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?w=800&h=400&fit=crop';
};
---

<section class="py-20 bg-slate-50">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 mb-4">
        {title}
      </h2>
      {subtitle && (
        <p class="text-lg text-slate-600 max-w-2xl mx-auto">
          {subtitle}
        </p>
      )}
    </div>

    <!-- Blog Grid -->
    {posts.length > 0 ? (
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {posts.map((post) => {
          const hasImage = post.data.image;
          const imageUrl = hasImage || getFallbackImage(post.data.category);
          
          return (
            <a 
              href={`/blog/${post.slug}`}
              class="group h-full block focus:outline-none focus:ring-2 focus:ring-[#1A5F9E] focus:ring-offset-2 rounded-xl"
            >
              <Card class="h-full flex flex-col overflow-hidden hover:shadow-xl transition-shadow duration-300">
                <!-- Post Image with Fallback -->
                <div class="relative h-48 overflow-hidden bg-gradient-to-br from-slate-200 to-slate-300">
                  <img
                    src={imageUrl}
                    alt={post.data.title}
                    loading="lazy"
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                    onerror="this.onerror=null; this.src='https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?w=800&h=400&fit=crop'"
                  />
                  
                  {/* Fallback Icon Overlay (only shown when image fails to load) */}
                  {!hasImage && (
                    <div class="absolute inset-0 flex items-center justify-center bg-slate-800/50">
                      <svg class="w-12 h-12 text-white/70" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                      </svg>
                    </div>
                  )}
                  
                  {/* Category Badge on Image (optional enhancement) */}
                  <div class="absolute top-3 left-3">
                    <Badge variant="secondary" class="text-xs bg-white/90 backdrop-blur-sm">
                      {post.data.category || 'Article'}
                    </Badge>
                  </div>
                </div>
                
                {/* Post Content */}
                <div class="flex-1 p-6 flex flex-col">
                  {/* Title */}
                  <h3 class="text-xl font-bold text-slate-900 mb-3 group-hover:text-[#1A5F9E] transition-colors line-clamp-2">
                    {post.data.title}
                  </h3>
                  
                  {/* Description */}
                  {post.data.description && (
                    <p class="text-slate-600 text-sm mb-4 line-clamp-2">
                      {post.data.description}
                    </p>
                  )}
                  
                  {/* Metadata */}
                  <div class="flex items-center justify-between pt-4 border-t border-slate-200 mt-auto text-sm text-slate-500">
                    <span class="font-medium">
                      {post.data.author || 'Berojgar Engineer'}
                    </span>
                    <time datetime={post.data.date.toISOString()}>
                      {new Date(post.data.date).toLocaleDateString('en-US', {
                        year: 'numeric',
                        month: 'short',
                        day: 'numeric'
                      })}
                    </time>
                  </div>
                </div>
              </Card>
            </a>
          );
        })}
      </div>
    ) : (
      <div class="text-center py-12">
        <p class="text-slate-500">No blog posts found.</p>
      </div>
    )}

    <!-- View All CTA -->
    {showViewAll && posts.length > 0 && (
      <div class="text-center mt-16">
        <a
          href="/blog"
          class="inline-flex items-center justify-center gap-2 px-8 py-3.5 text-base font-semibold text-white bg-gradient-to-r from-[#0F3D78] to-[#1A5F9E] rounded-xl hover:from-[#0A2B52] hover:to-[#0F3D78] transition-all duration-200 hover:shadow-lg"
        >
          View all articles
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
          </svg>
        </a>
      </div>
    )}
  </div>
</section>
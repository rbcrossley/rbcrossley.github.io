---
import { link } from '../lib/link';
export interface Props {
  items: { title: string; href: string }[];
}
const { items } = Astro.props;
---
<aside class="discover">
  <h3 class="title">Discover more</h3>
  <ul>
    {items.map((it) => (
      <li>
        <a href={link(it.href)}>
          <span>{it.title}</span>
          <span class="arrow">›</span>
        </a>
      </li>
    ))}
  </ul>
</aside>

<style>
  .discover { background: #fff; border: 1px solid var(--c-border); border-radius: 10px; padding: 18px; }
  .title { background: var(--c-primary-light); color: var(--c-text); padding: 12px 16px; margin: -18px -18px 12px; border-radius: 10px 10px 0 0; font-size: 18px; font-weight: 700; }
  .discover ul { list-style: none; padding: 0; margin: 0; }
  .discover li { border-bottom: 1px solid var(--c-border); }
  .discover li:last-child { border-bottom: 0; }
  .discover a { display: flex; align-items: center; justify-content: space-between; padding: 14px 4px; color: var(--c-text); text-decoration: none; font-size: 15px; font-weight: 500; transition: color 0.2s ease, padding-left 0.2s ease; }
  .discover a:hover { color: var(--c-primary); padding-left: 8px; }
  .arrow { color: var(--c-primary); font-size: 20px; }
</style>

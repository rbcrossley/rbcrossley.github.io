---
export interface Props {
  id?: string;
  name?: string;
  placeholder?: string;
  rows?: number;
  required?: boolean;
  class?: string;
}

const {
  id,
  name,
  placeholder,
  rows = 5,
  required,
  class: className = '',
} = Astro.props;
---
<textarea
  id={id}
  name={name}
  placeholder={placeholder}
  rows={rows}
  required={required}
  class={`ui-textarea ${className}`}
></textarea>

<style>
  .ui-textarea {
    width: 100%;
    border-radius: 1rem;
    border: 1px solid var(--c-card-border);
    background: #fff;
    padding: 0.95rem 1rem;
    font: inherit;
    color: var(--c-text);
    resize: vertical;
    line-height: 1.55;
    transition: border-color 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease;
  }

  .ui-textarea::placeholder {
    color: color-mix(in srgb, var(--c-muted) 76%, white);
  }

  .ui-textarea:focus {
    outline: none;
    border-color: var(--c-primary);
    box-shadow: 0 0 0 4px rgba(15, 61, 120, 0.12);
  }
</style>
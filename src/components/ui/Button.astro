---
export interface Props {
  href?: string;
  variant?: 'default' | 'secondary' | 'outline' | 'ghost';
  size?: 'sm' | 'default' | 'lg';
  type?: 'button' | 'submit' | 'reset';
  disabled?: boolean;
  target?: string;
  rel?: string;
  class?: string;
  id?: string;
}

const {
  href,
  variant = 'default',
  size = 'default',
  type = 'button',
  disabled = false,
  target,
  rel,
  class: className = '',
  id = undefined,
} = Astro.props;
const ariaExpanded = Astro.props['aria-expanded'];

const Tag = href ? 'a' : 'button';
---
<Tag
  id={id}
  href={href}
  type={href ? undefined : type}
  target={target}
  rel={rel}
  disabled={href ? undefined : disabled}
  data-variant={variant}
  data-size={size}
  aria-expanded={ariaExpanded}
  class={`ui-button ${className}`}
>
  <slot />
</Tag>

<style>
  .ui-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    border-radius: 999px;
    border: 1px solid transparent;
    font-weight: 600;
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease, background-color 0.2s ease, color 0.2s ease, border-color 0.2s ease;
    cursor: pointer;
    white-space: nowrap;
    box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04);
  }

  .ui-button:hover {
    transform: translateY(-1px);
  }

  .ui-button:focus-visible {
    outline: none;
    box-shadow: 0 0 0 4px rgba(15, 61, 120, 0.16);
  }

  .ui-button:disabled {
    opacity: 0.55;
    cursor: not-allowed;
    transform: none;
  }

  .ui-button[data-size='sm'] {
    height: 2.25rem;
    padding: 0 0.9rem;
    font-size: 0.875rem;
  }

  .ui-button[data-size='default'] {
    height: 2.75rem;
    padding: 0 1.1rem;
    font-size: 0.95rem;
  }

  .ui-button[data-size='lg'] {
    height: 3rem;
    padding: 0 1.35rem;
    font-size: 1rem;
  }

  .ui-button[data-variant='default'] {
    background: var(--c-primary);
    color: #fff;
    box-shadow: 0 12px 24px rgba(15, 61, 120, 0.18);
  }

  .ui-button[data-variant='default']:hover {
    background: var(--c-primary-dark);
  }

  .ui-button[data-variant='secondary'] {
    background: var(--c-primary-light);
    color: var(--c-primary-dark);
    border-color: var(--c-card-border);
  }

  .ui-button[data-variant='secondary']:hover {
    background: #dce8f8;
  }

  .ui-button[data-variant='outline'] {
    background: transparent;
    color: var(--c-primary-dark);
    border-color: var(--c-card-border);
  }

  .ui-button[data-variant='outline']:hover {
    background: rgba(15, 61, 120, 0.05);
    border-color: var(--c-primary);
  }

  .ui-button[data-variant='ghost'] {
    background: transparent;
    color: var(--c-primary-dark);
    box-shadow: none;
  }

  .ui-button[data-variant='ghost']:hover {
    background: rgba(15, 61, 120, 0.06);
  }
</style>
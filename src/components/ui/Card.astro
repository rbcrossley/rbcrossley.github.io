---
export interface Props {
  href?: string;
  padding?: 'none' | 'default';
  class?: string;
}

const { href, padding = 'default', class: className = '' } = Astro.props;
const Tag = href ? 'a' : 'div';
---
<Tag href={href} data-padding={padding} class={`ui-card ${className}`}>
  <slot />
</Tag>

<style>
  .ui-card {
    display: block;
    border-radius: 1.25rem;
    border: 1px solid var(--c-card-border);
    background: rgba(255, 255, 255, 0.92);
    color: var(--c-text);
    box-shadow: 0 16px 40px rgba(15, 23, 42, 0.06);
    backdrop-filter: blur(12px);
    padding: 1.25rem;
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease, background-color 0.2s ease;
    text-decoration: none;
  }

  .ui-card[data-padding='none'] {
    padding: 0;
  }

  .ui-card:hover {
    transform: translateY(-3px);
    border-color: rgba(15, 61, 120, 0.26);
    box-shadow: 0 22px 48px rgba(15, 23, 42, 0.09);
  }
</style>
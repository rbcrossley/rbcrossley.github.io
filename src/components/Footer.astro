---
import { link } from '../lib/link';
import Button from './ui/Button.astro';
---
<footer class="site-footer">
  <div class="footer-inner">
    <div class="col">
      <div class="logo-mark">BE</div>
      <p class="about">Berojgar Engineer is your virtual classroom, dedicated to empowering computer science students with comprehensive insights and practical knowledge.</p>
      <Button href={link('/contact')} variant="secondary" size="sm" class="footer-cta">Get in touch</Button>
    </div>
    <div class="col">
      <h4>Quick Links</h4>
      <ul>
        <li><a href={link('/')}>Home</a></li>
        <li><a href={link('/courses')}>Courses</a></li>
        <li><a href={link('/blog')}>Blog</a></li>
        <li><a href={link('/about')}>About Us</a></li>
        <li><a href={link('/contact')}>Contact us</a></li>
      </ul>
    </div>
    <div class="col">
      <h4>Legal</h4>
      <ul>
        <li><a href={link('/privacy-policy')}>Privacy Policy</a></li>
        <li><a href={link('/terms')}>Terms &amp; Conditions</a></li>
        <li><a href={link('/disclaimer')}>Disclaimer</a></li>
        <li><a href={link('/cookie-policy')}>Cookie Policy</a></li>
      </ul>
    </div>
    <div class="col">
      <h4>Contribute</h4>
      <ul>
        <li><a href={link('/suggest-a-topic')}>Suggest a topic</a></li>
        <li><a href={link('/become-a-contributer')}>Become a Contributor</a></li>
      </ul>
    </div>
  </div>
  <div class="footer-bottom">
    <p>© {new Date().getFullYear()} Berojgar Engineer. All rights reserved.</p>
  </div>
</footer>

<style>
  .site-footer {
    width: 100%;
    background: linear-gradient(180deg, #08111f 0%, #050c16 100%);
    color: var(--c-footer-text);
    margin-top: auto;
    border-top: 1px solid rgba(220, 231, 247, 0.08);
  }

  .footer-inner {
    max-width: 1240px;
    margin: 0 auto;
    padding: 56px 24px 32px;
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1fr 1fr;
    gap: 28px;
    width: 100%;
  }

  .col h4 {
    color: #fff;
    font-size: 1rem;
    font-weight: 700;
    margin: 0 0 16px;
  }

  .col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .col a {
    color: var(--c-footer-text);
    text-decoration: none;
    font-size: 0.92rem;
    transition: color 0.2s ease;
  }

  .col a:hover {
    color: #fff;
  }

  .logo-mark {
    width: 56px;
    height: 50px;
    border-radius: 16px;
    background: linear-gradient(135deg, var(--c-primary), var(--c-primary-dark));
    color: #fff;
    font-weight: 800;
    font-size: 1rem;
    letter-spacing: 0.08em;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 14px;
    box-shadow: 0 18px 30px rgba(15, 61, 120, 0.22);
  }

  .about {
    color: rgba(220, 231, 247, 0.82);
    font-size: 0.94rem;
    line-height: 1.7;
    max-width: 380px;
    margin-bottom: 18px;
  }

  .footer-cta {
    margin-top: 4px;
  }

  .footer-bottom {
    width: 100%;
    background: rgba(255, 255, 255, 0.03);
    padding: 16px 24px;
    text-align: center;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .footer-bottom p {
    margin: 0;
    font-size: 0.84rem;
    color: rgba(220, 231, 247, 0.65);
  }

  @media (max-width: 1024px) { .footer-inner { grid-template-columns: 1fr 1fr 1fr; } }
  @media (max-width: 700px) { .footer-inner { grid-template-columns: 1fr 1fr; padding: 40px 18px; } }
  @media (max-width: 480px) { .footer-inner { grid-template-columns: 1fr; } }
</style>

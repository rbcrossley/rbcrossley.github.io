---
import { link } from '../lib/link';
import Button from './ui/Button.astro';
import Input from './ui/Input.astro';
---

<header class="site-header">
  <div class="header-inner">
    <a href={link('/')} class="logo-wrap" aria-label="Berojgar Engineer Home">
      <span class="logo-mark">BE</span>
      <span class="brand-copy">
        <strong>Berojgar Engineer</strong>
        <span>Concept clarity for CS students</span>
      </span>
    </a>

    <nav class="main-nav" id="mainNav">
      <a href={link('/')} class="nav-link">Home</a>
      <a href={link('/blog')} class="nav-link">Blog</a>
      <a href={link('/about')} class="nav-link">About Us</a>
      <a href={link('/contact')} class="nav-link">Contact us</a>
    </nav>

    <form class="search-bar" role="search" onsubmit="event.preventDefault();">
      <Input type="search" placeholder="Search topics" aria-label="Search" class="search-input" />
      <Button type="submit" size="sm" class="search-btn">Search</Button>
    </form>

    <Button type="button" variant="ghost" size="sm" class="mobile-toggle" id="mobileToggle" aria-label="Toggle menu">
      Menu
    </Button>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    width: 100%;
    background: rgba(255, 255, 255, 0.88);
    backdrop-filter: blur(18px);
    border-bottom: 1px solid rgba(217, 227, 240, 0.9);
  }

  .header-inner {
    max-width: 1240px;
    margin: 0 auto;
    padding: 16px 24px;
    display: flex;
    align-items: center;
    gap: 18px;
  }

  .logo-wrap {
    display: inline-flex;
    align-items: center;
    gap: 0.85rem;
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: 18px;
    background: linear-gradient(135deg, var(--c-primary), var(--c-primary-dark));
    color: #fff;
    font-weight: 800;
    font-size: 1.05rem;
    letter-spacing: 0.08em;
    box-shadow: 0 18px 30px rgba(15, 61, 120, 0.2);
  }

  .brand-copy {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .brand-copy strong {
    font-size: 1rem;
    color: var(--c-text);
  }

  .brand-copy span {
    font-size: 0.82rem;
    color: var(--c-muted);
  }

  .main-nav {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex: 1;
    justify-content: center;
  }

  .nav-link {
    color: var(--c-text);
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
    padding: 0.65rem 0.95rem;
    border-radius: 999px;
    transition: background-color 0.2s ease, color 0.2s ease, transform 0.2s ease;
  }

  .nav-link:hover,
  .nav-link.active {
    color: var(--c-primary-dark);
    background: var(--c-primary-light);
  }

  .search-bar {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    width: min(320px, 30vw);
    padding: 0.35rem;
    border-radius: 999px;
    border: 1px solid var(--c-card-border);
    background: rgba(255, 255, 255, 0.94);
    box-shadow: 0 14px 30px rgba(15, 23, 42, 0.05);
  }

  .search-input {
    border: 0;
    background: transparent;
    box-shadow: none;
    height: 2.4rem;
    padding: 0.55rem 0.75rem;
  }

  .search-input:focus {
    box-shadow: none;
  }

  .search-btn {
    flex-shrink: 0;
  }

  .mobile-toggle {
    display: none;
  }

  @media (max-width: 1100px) {
    .brand-copy { display: none; }
    .search-bar { width: 260px; }
    .main-nav { gap: 0.15rem; }
  }

  @media (max-width: 860px) {
    .main-nav {
      position: absolute;
      top: calc(100% + 0.75rem);
      left: 24px;
      right: 24px;
      background: rgba(255, 255, 255, 0.98);
      flex-direction: column;
      align-items: stretch;
      gap: 0.2rem;
      padding: 0.75rem;
      display: none;
      border: 1px solid var(--c-card-border);
      border-radius: 1.25rem;
      box-shadow: 0 24px 54px rgba(15, 23, 42, 0.12);
    }

    .main-nav.open { display: flex; }

    .nav-link {
      width: 100%;
      padding: 0.85rem 1rem;
    }

    .search-bar { display: none; }

    .mobile-toggle { display: inline-flex; }
  }

  @media (max-width: 540px) {
    .header-inner { padding: 14px 18px; gap: 10px; }
    .logo-mark { width: 52px; height: 52px; border-radius: 16px; }
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const toggle = document.getElementById('mobileToggle');
    const nav = document.getElementById('mainNav');
    if (toggle && nav) {
      toggle.addEventListener('click', () => {
        const isOpen = nav.classList.toggle('open');
        toggle.setAttribute('aria-expanded', String(isOpen));
      });
    }
    const path = window.location.pathname.replace(/\/+$/, '') || '/';
    document.querySelectorAll('.nav-link').forEach((a) => {
      const href = (a.getAttribute('href') || '').replace(/\/+$/, '') || '/';
      if (href === path) a.classList.add('active');
    });
  });
</script>

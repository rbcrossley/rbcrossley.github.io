---
import { link } from '../lib/link';
---

<header class="site-header">
  <div class="header-inner">
    <a href={link('/')} class="logo-wrap" aria-label="Berojgar Engineer Home">
      <span class="logo-mark">BE</span>
    </a>

    <nav class="main-nav" id="mainNav">
      <a href={link('/')} class="nav-link">Home</a>
      <a href={link('/blog')} class="nav-link">Blog</a>
      <a href={link('/about')} class="nav-link">About Us</a>
      <a href={link('/contact')} class="nav-link">Contact us</a>
    </nav>

    <form class="search-bar" role="search" onsubmit="event.preventDefault();">
      <input type="text" placeholder="Search..." aria-label="Search" />
      <button type="submit" aria-label="Search button">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"></circle><path d="M21 21l-3.5-3.5"></path></svg>
      </button>
    </form>

    <button class="mobile-toggle" id="mobileToggle" aria-label="Toggle menu">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
    </button>
  </div>
</header>

<style>
  .site-header { background: var(--c-primary-light); width: 100%; position: sticky; top: 0; z-index: 50; }
  .header-inner { max-width: 1280px; margin: 0 auto; padding: 18px 28px; display: flex; align-items: center; gap: 28px; }
  .logo-wrap { display: inline-flex; align-items: center; text-decoration: none; }
  .logo-mark { display: inline-flex; align-items: center; justify-content: center; width: 64px; height: 56px; border-radius: 6px; background: var(--c-logo); color: #fff; font-family: 'Poppins', sans-serif; font-weight: 800; font-style: italic; font-size: 30px; letter-spacing: -1px; box-shadow: 0 2px 6px rgba(160, 32, 32, 0.25); }
  .main-nav { display: flex; align-items: center; gap: 28px; flex: 1; justify-content: center; }
  .nav-link { color: #2A2A2A; font-weight: 600; font-size: 16px; text-decoration: none; padding: 6px 2px; transition: color 0.2s ease; position: relative; }
  .nav-link:hover { color: var(--c-primary); }
  .nav-link.active { color: var(--c-primary); }
  .caret { font-size: 10px; margin-left: 2px; }
  .nav-dropdown { position: relative; }
  .nav-dropdown:hover .dropdown-panel,
  .nav-dropdown:focus-within .dropdown-panel { opacity: 1; visibility: visible; transform: translate(-50%, 0); }
  .dropdown-panel { position: absolute; top: 100%; left: 50%; transform: translate(-50%, 8px); min-width: 240px; background: #fff; border-radius: 8px; box-shadow: 0 12px 30px rgba(0, 0, 0, 0.12); padding: 8px 0; opacity: 0; visibility: hidden; transition: opacity 0.18s ease, transform 0.18s ease; z-index: 60; }
  .dropdown-panel a { display: block; padding: 10px 18px; color: #2A2A2A; text-decoration: none; font-size: 14px; font-weight: 500; }
  .dropdown-panel a:hover { background: var(--c-primary-light); color: var(--c-primary); }
  .search-bar { display: flex; align-items: center; background: #fff; border-radius: 999px; padding: 4px 4px 4px 18px; box-shadow: 0 1px 4px rgba(0, 0, 0, 0.06); width: 280px; }
  .search-bar input { border: 0; outline: 0; flex: 1; font-size: 14px; background: transparent; color: #2A2A2A; }
  .search-bar button { border: 0; background: var(--c-logo); color: #fff; width: 36px; height: 36px; border-radius: 999px; display: inline-flex; align-items: center; justify-content: center; cursor: pointer; transition: background 0.2s ease; }
  .search-bar button:hover { background: var(--c-primary-dark); }
  .mobile-toggle { display: none; background: transparent; border: 0; cursor: pointer; color: #2A2A2A; }
  @media (max-width: 1024px) { .search-bar { width: 200px; } .main-nav { gap: 18px; } }
  @media (max-width: 860px) {
    .main-nav { position: absolute; top: 100%; left: 0; right: 0; background: var(--c-primary-light); flex-direction: column; gap: 0; padding: 12px 24px 24px; display: none; border-top: 1px solid var(--c-border); }
    .main-nav.open { display: flex; }
    .nav-link { width: 100%; padding: 12px 0; border-bottom: 1px solid var(--c-border); }
    .dropdown-panel { position: static; transform: none; box-shadow: none; opacity: 1; visibility: visible; background: transparent; }
    .search-bar { width: 180px; }
    .mobile-toggle { display: inline-flex; }
  }
  @media (max-width: 540px) {
    .header-inner { padding: 14px 18px; gap: 12px; }
    .search-bar { display: none; }
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const toggle = document.getElementById('mobileToggle');
    const nav = document.getElementById('mainNav');
    if (toggle && nav) toggle.addEventListener('click', () => nav.classList.toggle('open'));
    const path = window.location.pathname.replace(/\/+$/, '') || '/';
    document.querySelectorAll('.nav-link').forEach((a) => {
      const href = (a.getAttribute('href') || '').replace(/\/+$/, '') || '/';
      if (href === path) a.classList.add('active');
    });
  });
</script>

---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { link } from '../../lib/link';
import Button from '../../components/ui/Button.astro';
import Badge from '../../components/ui/Badge.astro';
import Card from '../../components/ui/Card.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((p) => ({ params: { slug: p.slug }, props: { post: p } }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---
<Base title={`${post.data.title} » Berojgar Engineer`} description={post.data.description}>
  <article class="blog-article section-shell">
    <header class="head">
      <Button href={link('/blog')} variant="ghost">← Back to blog</Button>
      <h1>{post.data.title}</h1>
      <div class="meta">
        <Badge variant="outline">{post.data.author}</Badge>
        <Badge variant="secondary">{new Date(post.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</Badge>
      </div>
    </header>
    <Card class="hero-banner" padding="none">
      <div class="banner" style={post.data.image ? `background-image: url('${post.data.image}'); background-size: cover; background-position: top center;` : ''}></div>
    </Card>
    <Card class="content-card">
      <div class="content">
        <Content />
      </div>
    </Card>
  </article>
</Base>

<style>
  .blog-article { max-width: 860px; margin: 0 auto; padding-inline: 24px; }
  .head { margin-bottom: 20px; display: flex; flex-direction: column; gap: 14px; }
  .head h1 { font-size: clamp(2rem, 3vw, 3rem); line-height: 1.15; }
  .meta { display: flex; gap: 10px; flex-wrap: wrap; color: var(--c-muted); font-size: 0.9rem; }
  .hero-banner { overflow: hidden; margin: 14px 0 24px; }
  .banner { aspect-ratio: 21/9; background: linear-gradient(135deg, var(--c-primary), var(--c-primary-dark)); border-radius: inherit; }
  .content-card { }
  .content :global(h1) { font-size: 32px; font-weight: 700; margin: 30px 0 16px; color: var(--c-text); }
  .content :global(h2) { font-size: 26px; margin: 28px 0 14px; }
  .content :global(h3) { font-size: 20px; margin: 22px 0 10px; }
  .content :global(p) { line-height: 1.85; margin: 0 0 16px; font-size: 16px; }
  .content :global(ul), .content :global(ol) { margin: 0 0 18px 22px; line-height: 1.85; }
  .content :global(ol) { list-style-type: decimal; }
  .content :global(ul) { list-style-type: disc; }
  .content :global(li) { margin-bottom: 8px; }
  .content :global(a) { color: var(--c-primary); text-decoration: underline; font-weight: 500; cursor: pointer; transition: opacity 0.2s ease; }
  .content :global(a:hover) { opacity: 0.8; }
  .content :global(table) { width: 100%; border-collapse: collapse; margin: 16px 0 24px; }
.content :global(th), .content :global(td) { border: 1px solid var(--c-border); padding: 12px; text-align: left; }
.content :global(th) { background: var(--c-card-bg); font-weight: 600; }
.content :global(tr:hover) { background: var(--c-card-hover); }
.content :global(blockquote) { margin: 16px 0; padding: 12px 16px; border-left: 4px solid var(--c-primary); background: var(--c-card-bg); font-style: italic; color: var(--c-muted); }

  @media (max-width: 640px) {
    .blog-article { padding-inline: 18px; }
  }
</style>

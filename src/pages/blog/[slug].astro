---
import { getCollection, type CollectionEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { link } from '../../lib/link';
import Button from '../../components/ui/Button.astro';
import Badge from '../../components/ui/Badge.astro';
import Card from '../../components/ui/Card.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((p: CollectionEntry<'blog'>) => ({ params: { slug: p.slug }, props: { post: p } }));
}

const { post } = Astro.props as { post: CollectionEntry<'blog'> };
const { Content } = await post.render();
---
<Base title={`${post.data.title} - Berojgar Engineer`} description={post.data.description}>
  <article class="mx-auto max-w-[860px] px-6 py-12 sm:py-14 section-shell">
    <header class="mb-5 flex flex-col gap-3.5">
      <Button href={link('/blog')} variant="ghost">← Back to blog</Button>
      <h1 class="text-[clamp(2rem,3vw,3rem)] font-bold leading-[1.15] text-[var(--c-text)]">{post.data.title}</h1>
      <div class="flex flex-wrap gap-2.5 text-sm text-[var(--c-muted)]">
        <Badge variant="outline">{post.data.author}</Badge>
        <Badge variant="secondary">{new Date(post.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</Badge>
      </div>
    </header>
    <Card class="overflow-hidden p-0" padding="none">
      <div class="aspect-[21/9] rounded-[inherit] bg-gradient-to-br from-[var(--c-primary)] to-[var(--c-primary-dark)]" style={post.data.image ? `background-image: url('${post.data.image}'); background-size: cover; background-position: top center;` : ''}></div>
    </Card>
    <Card class="mt-6">
      <div class="prose prose-slate max-w-none prose-headings:text-[var(--c-text)] prose-a:text-[var(--c-primary)] prose-a:underline prose-blockquote:border-l-[var(--c-primary)] prose-blockquote:bg-[var(--c-card-bg)] prose-blockquote:text-[var(--c-muted)] prose-th:bg-[var(--c-card-bg)] prose-tr:hover:bg-[var(--c-card-hover)] prose-img:rounded-xl prose-img:my-4 prose-table:w-full prose-table:border-collapse prose-th:border prose-th:border-[var(--c-border)] prose-td:border prose-td:border-[var(--c-border)] prose-th:px-3 prose-th:py-3 prose-td:px-3 prose-td:py-3">
        <Content />
      </div>
    </Card>
  </article>
</Base>

---
import { getCollection, type CollectionEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { link } from '../../lib/link';
import Button from '../../components/ui/Button.astro';
import Badge from '../../components/ui/Badge.astro';
import Card from '../../components/ui/Card.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((p: CollectionEntry<'blog'>) => ({ params: { slug: p.slug }, props: { post: p } }));
}

const { post } = Astro.props as { post: CollectionEntry<'blog'> };
const { Content } = await post.render();

// Helper for fallback image
const getFallbackImage = (category?: string) => {
  const fallbacks: Record<string, string> = {
    'Tutorial': 'https://images.unsplash.com/photo-1516116216624-53e697fedbea?w=1600&h=800&fit=crop',
    'Career': 'https://images.unsplash.com/photo-1522071820081-009f0129c71c?w=1600&h=800&fit=crop',
    'Industry': 'https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=1600&h=800&fit=crop',
    'Review': 'https://images.unsplash.com/photo-1532619187608-e5375cab36aa?w=1600&h=800&fit=crop'
  };
  return fallbacks[category || ''] || 'https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?w=1600&h=800&fit=crop';
};

const hasImage = post.data.image;
const imageUrl = hasImage || getFallbackImage(post.data.category);
---

<Base title={`${post.data.title} - Berojgar Engineer`} description={post.data.description}>
  <article class="max-w-4xl mx-auto px-6 py-12 sm:py-14">
    <!-- Header -->
    <header class="mb-8 flex flex-col gap-4">
      <a href={link('/blog')} class="inline-flex items-center gap-2 text-slate-600 hover:text-[#1A5F9E] transition-colors text-sm font-medium">
        ← Back to blog
      </a>
      <h1 class="text-4xl sm:text-5xl font-bold leading-tight text-slate-900">
        {post.data.title}
      </h1>
      <div class="flex flex-wrap gap-2 text-sm text-slate-600">
        <Badge variant="outline">{post.data.author || 'Berojgar Engineer'}</Badge>
        <Badge variant="secondary">
          {new Date(post.data.date).toLocaleDateString('en-US', { 
            year: 'numeric', 
            month: 'long', 
            day: 'numeric' 
          })}
        </Badge>
      </div>
    </header>

    <!-- Featured Image -->
    <div class="relative rounded-xl overflow-hidden bg-gradient-to-br from-slate-200 to-slate-300 mb-8">
      <div class="aspect-[21/9]">
        <img
          src={imageUrl}
          alt={post.data.title}
          class="w-full h-full object-cover"
          onerror="this.onerror=null; this.src='https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?w=1600&h=800&fit=crop'"
        />
      </div>
      {!hasImage && (
        <div class="absolute inset-0 flex items-center justify-center bg-slate-800/50">
          <svg class="w-16 h-16 text-white/60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
          </svg>
        </div>
      )}
    <div class="hero-banner" style={post.data.image ? `background-image: url('${post.data.image}'); background-size: contain; background-position: center; background-repeat: no-repeat;` : ''}></div>
    <div class="content">
      <Content />
    </div>

    <!-- Content -->
    <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
      <div class="p-6 sm:p-8">
        <div class="prose prose-slate max-w-none 
          prose-headings:text-slate-900 
          prose-headings:font-bold 
          prose-h1:text-3xl 
          prose-h2:text-2xl 
          prose-h3:text-xl 
          prose-p:text-slate-700 
          prose-p:leading-relaxed 
          prose-a:text-[#1A5F9E] 
          prose-a:no-underline 
          prose-a:hover:underline 
          prose-strong:text-slate-900 
          prose-code:text-[#1A5F9E] 
          prose-code:bg-slate-100 
          prose-code:px-1 
          prose-code:py-0.5 
          prose-code:rounded 
          prose-code:text-sm 
          prose-pre:bg-slate-900 
          prose-pre:text-slate-100 
          prose-blockquote:border-l-4 
          prose-blockquote:border-[#1A5F9E] 
          prose-blockquote:bg-slate-50 
          prose-blockquote:py-2 
          prose-blockquote:px-4 
          prose-blockquote:text-slate-600 
          prose-blockquote:italic 
          prose-ul:text-slate-700 
          prose-ol:text-slate-700 
          prose-li:my-1 
          prose-img:rounded-lg 
          prose-img:my-6 
          prose-img:shadow-md 
          prose-table:w-full 
          prose-table:border-collapse 
          prose-th:border 
          prose-th:border-slate-200 
          prose-th:bg-slate-50 
          prose-th:px-4 
          prose-th:py-2 
          prose-th:text-left 
          prose-td:border 
          prose-td:border-slate-200 
          prose-td:px-4 
          prose-td:py-2">
          <Content />
        </div>
      </div>
    </div>
  </article>
</Base>
---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { link } from '../../lib/link';
import Button from '../../components/ui/Button.astro';
import Card from '../../components/ui/Card.astro';
import Badge from '../../components/ui/Badge.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => +new Date(b.data.date) - +new Date(a.data.date)
);
---
<Base title="Blog - Berojgar Engineer" description="Latest articles on computer science topics">
  <section class="page section-shell">
    <div class="container">
      <div class="page-head">
        <div>
          <span class="eyebrow">Blog</span>
          <h1 class="page-title">Latest from the blog</h1>
          <p class="page-sub">Articles, tutorials and tips for computer science students.</p>
        </div>
        <Button href={link('/contact')} variant="outline">Suggest a topic</Button>
      </div>

      <div class="blog-grid">
        {posts.map((post) => (
          <Card href={link(`/blog/${post.slug}`)} padding="none" class="blog-card">
            <div class="blog-image">
              <Badge class="blog-tag text-white">Blog</Badge>
            </div>
            <div class="blog-body">
              <h3>{post.data.title}</h3>
              <p>{post.data.description}</p>
              <time>{new Date(post.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
              <span class="read-more">Read more</span>
            </div>
          </Card>
        ))}
      </div>
    </div>
  </section>
</Base>

<style>
  .page-head {
    display: flex;
    justify-content: space-between;
    align-items: end;
    gap: 1rem;
    margin-bottom: 28px;
  }

  .page-title {
    font-size: clamp(2rem, 3vw, 3rem);
    margin-top: 0.35rem;
    color: var(--c-text);
  }

  .page-sub {
    color: var(--c-muted);
    margin: 0.7rem 0 0;
    max-width: 58ch;
    line-height: 1.7;
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  .blog-card {
    overflow: hidden;
  }

  .blog-image {
    aspect-ratio: 16/9;
    background: linear-gradient(135deg, var(--c-primary), var(--c-primary-dark));
    position: relative;
  }

  .blog-tag {
    position: absolute;
    top: 1rem;
    left: 1rem;
  }

  .blog-body {
    padding: 1.15rem 1.2rem 1.25rem;
  }

  .blog-body h3 {
    font-size: 1.08rem;
    line-height: 1.45;
    margin-bottom: 0.5rem;
  }

  .blog-body p {
    font-size: 0.94rem;
    color: var(--c-muted);
    margin: 0 0 0.85rem;
    line-height: 1.65;
  }

  .blog-body time {
    font-size: 0.82rem;
    color: var(--c-muted);
  }

  .read-more {
    display: block;
    color: var(--c-primary);
    font-weight: 700;
    font-size: 0.9rem;
    margin-top: 0.9rem;
  }

  @media (max-width: 1024px) { .blog-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
  @media (max-width: 720px) { .page-head { flex-direction: column; align-items: start; } }
  @media (max-width: 640px) { .blog-grid { grid-template-columns: 1fr; } }
</style>

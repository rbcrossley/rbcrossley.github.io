---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import Base from '../layouts/Base.astro';
import HeroSection from '../components/sections/HeroSection.astro';
import HeroIllustration from '../components/sections/HeroIllustration.astro';
import BlogSection from '../components/sections/BlogSection.astro';
import FeatureBanner from '../components/sections/FeatureBanner.astro';

const blogPosts = ((await getCollection('blog')) as CollectionEntry<'blog'>[])
  .sort((a, b) => +new Date(b.data.date).getTime() - +new Date(a.data.date).getTime())
  .slice(0, 3);
---

<Base title="Berojgar Engineer - Concept Clarity for CS Students">
  <!-- Hero Section with Illustration -->
  <HeroSection posts={blogPosts}>
    <HeroIllustration posts={blogPosts} slot="illustration" />
  </HeroSection>

  <!-- Blog Section -->
  <BlogSection posts={blogPosts} />

  <!-- Feature Banner -->
  <FeatureBanner />
</Base>
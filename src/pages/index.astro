---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import { link } from '../lib/link';
import Button from '../components/ui/Button.astro';
import Card from '../components/ui/Card.astro';
import Badge from '../components/ui/Badge.astro';

const courses = await getCollection('courses');
const blogPosts = (await getCollection('blog'))
  .sort((a, b) => +new Date(b.data.date) - +new Date(a.data.date))
  .slice(0, 3);
---
<Base title="Berojgar Engineer - Concept Clarity for CS Students">
  <section class="hero">
    <div class="hero-inner container">
      <div class="hero-text">
        <Badge variant="secondary">Educational blog for CS students</Badge>
        <h1>Concept clarity for computer science students.</h1>
        <p>
          Berojgar Engineer is your virtual classroom for practical, beginner-friendly explanations. Explore structured lessons, short notes, and articles that make hard concepts easier to retain.
        </p>
        <div class="hero-cta">
          <Button href={link('/courses')} size="lg">Explore Courses</Button>
          <Button href={link('/blog')} variant="outline" size="lg">Read Blog</Button>
        </div>
        <div class="hero-meta">
          <div class="meta-card">
            <strong>Structured learning</strong>
            <span>Courses grouped by subject and topic depth.</span>
          </div>
          <div class="meta-card">
            <strong>Clear explanations</strong>
            <span>Designed for students who want concepts to click faster.</span>
          </div>
        </div>
      </div>
      <Card class="hero-illu">
        <div class="hero-panel-top">
          <Badge variant="outline">Live learning hub</Badge>
          <span>Built to keep explanations organized and easy to revisit.</span>
        </div>
        <svg viewBox="0 0 520 520" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <defs>
            <linearGradient id="heroBlue" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" stop-color="#0F3D78"/>
              <stop offset="100%" stop-color="#0A2B52"/>
            </linearGradient>
          </defs>
          <ellipse cx="260" cy="450" rx="230" ry="30" fill="#DCE8F7" opacity="0.95"/>
          <rect x="104" y="84" width="70" height="64" rx="16" fill="#EAF1FA" stroke="#C9D8EB" stroke-width="2"/>
          <text x="139" y="123" font-family="IBM Plex Sans" font-size="22" font-weight="700" fill="#0F3D78" text-anchor="middle">DSA</text>
          <rect x="104" y="168" width="70" height="64" rx="16" fill="#EAF1FA" stroke="#C9D8EB" stroke-width="2"/>
          <text x="139" y="207" font-family="IBM Plex Sans" font-size="20" font-weight="700" fill="#0F3D78" text-anchor="middle">OS</text>
          <rect x="104" y="252" width="70" height="64" rx="16" fill="#EAF1FA" stroke="#C9D8EB" stroke-width="2"/>
          <text x="139" y="291" font-family="IBM Plex Sans" font-size="20" font-weight="700" fill="#0F3D78" text-anchor="middle">DBMS</text>
          <rect x="198" y="74" width="132" height="84" rx="24" fill="url(#heroBlue)"/>
          <text x="264" y="118" font-family="Fraunces" font-size="24" font-weight="700" fill="#fff" text-anchor="middle">Learn better</text>
          <rect x="196" y="174" width="226" height="204" rx="26" fill="#fff" stroke="#D8E1EE" stroke-width="2"/>
          <rect x="216" y="196" width="178" height="10" rx="5" fill="#0F3D78"/>
          <rect x="216" y="220" width="152" height="8" rx="4" fill="#DCE8F7"/>
          <rect x="216" y="242" width="136" height="8" rx="4" fill="#DCE8F7"/>
          <rect x="216" y="264" width="164" height="8" rx="4" fill="#DCE8F7"/>
          <rect x="216" y="300" width="92" height="10" rx="5" fill="#0A2B52"/>
          <rect x="216" y="324" width="128" height="8" rx="4" fill="#DCE8F7"/>
          <rect x="216" y="346" width="108" height="8" rx="4" fill="#DCE8F7"/>
          <circle cx="402" cy="210" r="48" fill="#0F3D78" opacity="0.1"/>
          <circle cx="414" cy="216" r="30" fill="#0F3D78" opacity="0.16"/>
          <rect x="238" y="392" width="150" height="18" rx="9" fill="#EAF1FA"/>
        </svg>
      </Card>
    </div>
  </section>

  <section class="courses-section section-shell">
    <div class="container">
      <div class="section-head">
        <div>
          <span class="eyebrow">Browse subjects</span>
          <h2 class="section-title">Start with a structured topic track</h2>
        </div>
        <Button href={link('/courses')} variant="outline">View all courses</Button>
      </div>
      <div class="courses-grid">
        {courses.map((course) => (
          <Card href={link(`/${course.data.slug}`)} class="course-card">
            <div class="course-icon">
              <span>{course.data.short.split(' ').slice(0,2).map(w => w.charAt(0).toUpperCase()).join('')}</span>
            </div>
            <h3>{course.data.short}</h3>
            <p>{course.data.description}</p>
            <span class="link">Start learning</span>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <section class="blog-section section-shell">
    <div class="container">
      <div class="section-head">
        <div>
          <span class="eyebrow">Latest writing</span>
          <h2 class="section-title">Read the newest articles</h2>
        </div>
        <Button href={link('/blog')} variant="outline">View blog</Button>
      </div>
      <div class="blog-grid">
        {blogPosts.map((post) => (
          <Card href={link(`/blog/${post.slug}`)} padding="none" class="blog-card">
            <div
              class="blog-image"
              style={`background-image: ${post.data.image ? `url('${post.data.image}')` : `linear-gradient(135deg, var(--c-primary), var(--c-primary-dark))`};
                background-size: cover;
                background-position: center;`}
            >
              <Badge class="blog-tag">Blog</Badge>
            </div>
            <div class="blog-body">
              <h3>{post.data.title}</h3>
              <p>{post.data.description}</p>
              <span class="read-more">Read more</span>
              <div class="meta">{post.data.author} · No comments</div>
            </div>
          </Card>
        ))}
      </div>
      <div class="view-all-wrap">
        <Button href={link('/blog')} variant="outline">Browse the full blog</Button>
      </div>
    </div>
  </section>
</Base>

<style>
  .hero {
    background: linear-gradient(180deg, var(--c-hero-bg) 0%, #0f1b2c 100%);
    color: var(--c-hero-text);
    padding: 72px 0 88px;
    position: relative;
    overflow: hidden;
  }

  .hero::before,
  .hero::after {
    content: '';
    position: absolute;
    border-radius: 999px;
    background: radial-gradient(circle, rgba(220, 232, 255, 0.14), transparent 68%);
    pointer-events: none;
  }

  .hero::before { width: 320px; height: 320px; top: -120px; right: -80px; }
  .hero::after { width: 240px; height: 240px; bottom: -100px; left: -80px; }

  .hero-inner {
    display: grid;
    grid-template-columns: 1.1fr 0.95fr;
    gap: 36px;
    align-items: center;
    position: relative;
  }

  .hero-text {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .hero h1 {
    font-size: clamp(2.6rem, 4vw, 4.15rem);
    line-height: 1.06;
    color: var(--c-hero-accent);
    max-width: 12ch;
  }

  .hero p {
    font-size: 1.05rem;
    line-height: 1.8;
    color: rgba(248, 251, 255, 0.8);
    max-width: 640px;
    margin: 0;
  }

  .hero-cta {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 4px;
  }

  .hero-meta {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
    margin-top: 6px;
  }

  .meta-card {
    padding: 1rem 1.05rem;
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(220, 232, 255, 0.12);
    backdrop-filter: blur(12px);
  }

  .meta-card strong {
    display: block;
    margin-bottom: 0.35rem;
    color: #fff;
    font-size: 0.96rem;
  }

  .meta-card span {
    color: rgba(248, 251, 255, 0.72);
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .hero-illu {
    border-radius: 1.5rem;
    background: rgba(255, 255, 255, 0.94);
  }

  .hero-panel-top {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: center;
    margin-bottom: 1rem;
    color: var(--c-muted);
    font-size: 0.92rem;
  }

  .hero-illu svg {
    width: 100%;
    height: auto;
    display: block;
  }

  .section-head {
    display: flex;
    justify-content: space-between;
    align-items: end;
    gap: 1rem;
    margin-bottom: 24px;
  }

  .section-title {
    font-size: clamp(1.7rem, 2vw, 2.25rem);
    color: var(--c-text);
    margin-top: 0.35rem;
  }

  .courses-grid {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 18px;
  }

  .course-card {
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }

  .course-icon {
    width: 3.4rem;
    height: 3.4rem;
    border-radius: 1.1rem;
    background: var(--c-primary-light);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--c-primary-dark);
    font-weight: 800;
  }

  .course-card h3 {
    font-size: 1rem;
    line-height: 1.35;
  }

  .course-card p {
    color: var(--c-muted);
    font-size: 0.92rem;
    line-height: 1.65;
    margin: 0;
    flex: 1;
  }

  .link {
    color: var(--c-primary);
    font-weight: 700;
    font-size: 0.9rem;
  }

  .blog-section {
    background: transparent;
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  .blog-card {
    overflow: hidden;
  }

  .blog-image {
    aspect-ratio: 16 / 9;
    position: relative;
    border-bottom: 1px solid var(--c-card-border);
  }

  .blog-tag {
    position: absolute;
    top: 1rem;
    left: 1rem;
  }

  .blog-body {
    padding: 1.1rem 1.2rem 1.25rem;
  }

  .blog-body h3 {
    font-size: 1.08rem;
    line-height: 1.45;
    margin-bottom: 0.55rem;
  }

  .blog-body p {
    font-size: 0.94rem;
    color: var(--c-muted);
    margin: 0 0 0.9rem;
    line-height: 1.65;
  }

  .read-more {
    color: var(--c-primary);
    font-weight: 700;
    font-size: 0.9rem;
  }

  .meta {
    margin-top: 0.8rem;
    font-size: 0.82rem;
    color: var(--c-muted);
  }

  .view-all-wrap {
    display: flex;
    justify-content: center;
    margin-top: 26px;
  }

  @media (max-width: 1024px) {
    .hero-inner { grid-template-columns: 1fr; }
    .hero h1 { max-width: 14ch; }
    .courses-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    .blog-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (max-width: 768px) {
    .hero { padding-top: 58px; }
    .hero-illu { max-width: 520px; margin: 0 auto; order: -1; }
    .hero-meta { grid-template-columns: 1fr; }
    .section-head { align-items: start; flex-direction: column; }
    .courses-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .blog-grid { grid-template-columns: 1fr; }
  }
  @media (max-width: 480px) {
    .courses-grid { grid-template-columns: 1fr; }
  }
</style>

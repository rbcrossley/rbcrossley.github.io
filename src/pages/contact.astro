---
import Base from '../layouts/Base.astro';
---
<Base title="Contact us » Berojgar Engineer" description="Get in touch with the Berojgar Engineer team">
  <section class="page">
    <div class="container narrow">
      <h1 class="page-title">Contact us</h1>
      <p>For inquiries, please email <a href="mailto:admin@berojgarengineer.com">admin@berojgarengineer.com</a>.</p>
      <p>I typically respond within 48 hours and join the discord server(<a href="https://discord.gg/hJt3gTQakB">https://discord.gg/hJt3gTQakB</a>) for faster response.</p>
    </div>
  </section>
</Base>
<style>
  .page { padding: 50px 0 60px; }
  .narrow { max-width: 760px; }
  .page-title { font-size: 36px; font-weight: 800; margin-bottom: 12px; color: var(--c-text); }
  p { color: var(--c-muted); margin-bottom: 24px; }
</style>

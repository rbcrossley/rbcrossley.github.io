---
import Base from '../layouts/Base.astro';
import Button from '../components/ui/Button.astro';
import Input from '../components/ui/Input.astro';
import Textarea from '../components/ui/Textarea.astro';
import Card from '../components/ui/Card.astro';
---
<Base title="Contact us » Berojgar Engineer" description="Get in touch with the Berojgar Engineer team">
  <section class="page section-shell py-12 sm:py-14">
    <div class="container mx-auto max-w-[760px] px-6">
      <div class="mb-6">
        <div>
          <span class="eyebrow">Contact</span>
          <h1 class="mt-1.5 text-[clamp(2rem,3vw,3rem)] font-bold tracking-tight text-[var(--c-text)]">Contact us</h1>
          <p class="mt-3 leading-[1.75] text-[var(--c-muted)]">Have a question, suggestion, or feedback? Drop us a message and we’ll get back to you.</p>
        </div>
      </div>

      <Card class="p-0">
        <form class="flex flex-col gap-4 p-5 sm:p-6" onsubmit="event.preventDefault(); document.getElementById('cf-success').style.display='block'; this.reset();">
          <div class="grid gap-4 sm:grid-cols-2">
            <div class="flex flex-col gap-2.5">
              <label for="name" class="text-sm font-semibold text-[var(--c-text)]">Your name</label>
              <Input id="name" type="text" required placeholder="John Doe" />
            </div>
            <div class="flex flex-col gap-2.5">
              <label for="email" class="text-sm font-semibold text-[var(--c-text)]">Your email</label>
              <Input id="email" type="email" required placeholder="you@example.com" />
            </div>
          </div>
          <div class="flex flex-col gap-2.5">
            <label for="subject" class="text-sm font-semibold text-[var(--c-text)]">Subject</label>
            <Input id="subject" type="text" required placeholder="How can we help?" />
          </div>
          <div class="flex flex-col gap-2.5">
            <label for="message" class="text-sm font-semibold text-[var(--c-text)]">Message</label>
            <Textarea id="message" rows={6} required placeholder="Write your message here..." />
          </div>
          <Button type="submit">Send message</Button>
          <p id="cf-success" class="hidden font-semibold text-emerald-600">Thanks! Your message has been received (demo).</p>
        </form>
      </Card>
    </div>
  </section>
</Base>

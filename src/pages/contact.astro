---
import Base from '../layouts/Base.astro';
import Button from '../components/ui/Button.astro';
import Input from '../components/ui/Input.astro';
import Textarea from '../components/ui/Textarea.astro';
import Card from '../components/ui/Card.astro';
---
<Base title="Contact us » Berojgar Engineer" description="Get in touch with the Berojgar Engineer team">
  <section class="page section-shell">
    <div class="container narrow">
      <div class="page-head">
        <div>
          <span class="eyebrow">Contact</span>
          <h1 class="page-title">Contact us</h1>
          <p class="page-sub">Have a question, suggestion, or feedback? Drop us a message and we’ll get back to you.</p>
        </div>
      </div>

      <Card class="contact-card">
        <form class="contact-form" onsubmit="event.preventDefault(); document.getElementById('cf-success').style.display='block'; this.reset();">
          <div class="row">
            <div class="field">
              <label for="name">Your name</label>
              <Input id="name" type="text" required placeholder="John Doe" />
            </div>
            <div class="field">
              <label for="email">Your email</label>
              <Input id="email" type="email" required placeholder="you@example.com" />
            </div>
          </div>
          <div class="field">
            <label for="subject">Subject</label>
            <Input id="subject" type="text" required placeholder="How can we help?" />
          </div>
          <div class="field">
            <label for="message">Message</label>
            <Textarea id="message" rows={6} required placeholder="Write your message here..." />
          </div>
          <Button type="submit">Send message</Button>
          <p id="cf-success" class="success">Thanks! Your message has been received (demo).</p>
        </form>
      </Card>
    </div>
  </section>
</Base>
<style>
  .narrow { max-width: 760px; }

  .page-head {
    margin-bottom: 24px;
  }

  .page-title {
    font-size: clamp(2rem, 3vw, 3rem);
    margin-top: 0.35rem;
  }

  .page-sub {
    color: var(--c-muted);
    margin: 0.7rem 0 0;
    line-height: 1.75;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 9px;
  }

  label {
    font-weight: 600;
    font-size: 0.92rem;
    color: var(--c-text);
  }

  .success {
    display: none;
    color: #0f7a3f;
    font-weight: 600;
    margin-top: 4px;
  }

  @media (max-width: 640px) { .row { grid-template-columns: 1fr; } }
</style>

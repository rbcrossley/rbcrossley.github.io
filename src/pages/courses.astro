---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import { link } from '../lib/link';
import Button from '../components/ui/Button.astro';
import Card from '../components/ui/Card.astro';
import Badge from '../components/ui/Badge.astro';

const courses = await getCollection('courses');
---
<Base title="Courses » Berojgar Engineer" description="All computer science courses">
  <section class="page section-shell py-12 sm:py-14">
    <div class="container mx-auto px-6">
      <div class="mb-7 flex flex-col items-start justify-between gap-4 md:flex-row md:items-end">
        <div>
          <span class="eyebrow">Courses</span>
          <h1 class="mt-1.5 text-[clamp(2rem,3vw,3rem)] font-bold tracking-tight text-[var(--c-text)]">All courses</h1>
          <p class="mt-3 max-w-[70ch] leading-[1.7] text-[var(--c-muted)]">Pick a subject below and start learning. Each course includes structured topics, easy explanations, and quick-reference notes.</p>
        </div>
        <Button href={link('/blog')} variant="outline">Browse blog articles</Button>
      </div>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {courses.map((course) => (
          <Card href={link(`/${course.data.slug}`)} class="flex flex-col gap-3.5 text-[var(--c-text)] no-underline">
            <div class="inline-flex h-15 w-15 items-center justify-center rounded-[1.15rem] bg-[var(--c-primary-light)] text-[1.05rem] font-extrabold text-[var(--c-primary-dark)]">
              <span>{course.data.short.split(' ').slice(0,2).map(w => w.charAt(0).toUpperCase()).join('')}</span>
            </div>
            <h3 class="text-[1.1rem] font-semibold">{course.data.short}</h3>
            <p class="flex-1 text-[0.94rem] leading-[1.7] text-[var(--c-muted)]">{course.data.description}</p>
            <span class="text-sm font-bold text-[var(--c-primary)]">Start Learning →</span>
          </Card>
        ))}
      </div>
    </div>
  </section>
</Base>

---
import Base from '../layouts/Base.astro';
import { link } from '../lib/link';
import Card from '../components/ui/Card.astro';
import Button from '../components/ui/Button.astro';
import Badge from '../components/ui/Badge.astro';
---
<Base title="About Us » Berojgar Engineer" description="Learn more about Berojgar Engineer and our mission.">
  <section class="page section-shell py-12 sm:py-14">
    <div class="container mx-auto max-w-[840px] px-6">
      <div class="mb-7 flex flex-col items-start gap-4 md:flex-row md:items-end md:justify-between">
        <div>
          <span class="eyebrow">About</span>
          <h1 class="mt-1.5 text-[clamp(2rem,3vw,3rem)] font-bold tracking-tight text-[var(--c-text)]">About us</h1>
          <p class="mt-3 max-w-[66ch] leading-[1.75] text-[var(--c-muted)]">Berojgar Engineer is a virtual classroom built to make computer science concepts easier to understand, revisit, and apply.</p>
        </div>
        <Button href={link('/contact')} variant="outline">Contact us</Button>
      </div>

      <div class="grid gap-4 md:grid-cols-2">
        <Card class="col-span-full">
          <Badge variant="secondary">Mission</Badge>
          <p class="mt-3 leading-[1.75] text-[var(--c-muted)]"><strong>Berojgar Engineer</strong> helps CS students learn with confidence through practical explanations, well-structured notes, and articles that stay focused on what matters most.</p>
        </Card>

        <Card>
          <h2 class="mb-3 text-[1.15rem] font-semibold text-[var(--c-text)]">Our vision</h2>
          <p class="leading-[1.75] text-[var(--c-muted)]">To become the go-to resource for CS students worldwide, with free, high-quality educational content that feels clear and dependable.</p>
        </Card>

        <Card>
          <h2 class="mb-3 text-[1.15rem] font-semibold text-[var(--c-text)]">What we offer</h2>
          <ul class="ml-4 list-disc space-y-2 leading-[1.75] text-[var(--c-muted)]">
            <li>Structured course content for major CS subjects</li>
            <li>Beginner-friendly explanations</li>
            <li>Real-world examples and case studies</li>
            <li>Regular blog posts on industry trends and tips</li>
          </ul>
        </Card>

        <Card class="flex flex-col gap-3">
          <h2 class="text-[1.15rem] font-semibold text-[var(--c-text)]">Join the community</h2>
          <p class="leading-[1.75] text-[var(--c-muted)]">Have a topic you'd like us to cover or want to contribute your knowledge? We’d love to hear from you.</p>
          <Button href={link('/contact')}>Start a conversation</Button>
        </Card>
      </div>
    </div>
  </section>
</Base>

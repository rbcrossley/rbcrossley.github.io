---
import Base from '../layouts/Base.astro';
import { link } from '../lib/link';
---
<Base title="About Us » Berojgar Engineer" description="Learn more about Berojgar Engineer and our mission.">
  <section class="page">
    <div class="container narrow">
      <h1 class="page-title">About Us</h1>
      <p>
        I am from Nepal and graduated from Tribhuvan University as a Computer Engineer. I have worked as a support engineer in the fintech domain here in Nepal, and I am currently preparing for the Loksewa Computer Engineer and IT Officer examinations.
      </p>
      <p>
        If you have a question or would like to connect, please visit our <a href={link('/contact')}>contact page</a>.
      </p>
      <h2>Join Our Community</h2>
      <p>
        Join our community on Discord for updates, discussion, and exam support: <a href="https://discord.gg/hJt3gTQakB" target="_blank" rel="noopener">https://discord.gg/hJt3gTQakB</a>
      </p>
    </div>
  </section>
</Base>
<style>
  .page { padding: 50px 0 60px; }
  .narrow { max-width: 800px; }
  .page-title { font-size: 36px; font-weight: 800; margin-bottom: 20px; color: var(--c-text); }
  h2 { font-size: 22px; margin: 26px 0 12px; color: var(--c-primary-dark); }
  p { line-height: 1.85; margin: 0 0 16px; }
  ul { margin: 0 0 16px 22px; line-height: 1.85; }
  a { color: var(--c-primary); text-decoration: underline; }
</style>

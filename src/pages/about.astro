---
import Base from '../layouts/Base.astro';
import { link } from '../lib/link';
import Card from '../components/ui/Card.astro';
import Button from '../components/ui/Button.astro';
import Badge from '../components/ui/Badge.astro';
---

<Base title="About Us » Berojgar Engineer" description="Learn more about Berojgar Engineer and our mission.">
  <section class="py-12 sm:py-14 bg-white">
    <div class="max-w-4xl mx-auto px-6">
      <!-- Header -->
      <div class="mb-8 flex flex-col items-start gap-4 md:flex-row md:items-end md:justify-between">
        <div>
          <span class="text-sm font-semibold text-[#1A5F9E] uppercase tracking-wider">About</span>
          <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-slate-900 mt-1">
            About us
          </h1>
          <p class="text-slate-600 mt-3 max-w-[66ch] leading-relaxed">
            Berojgar Engineer is a virtual classroom built to make computer science concepts easier to understand, revisit, and apply.
          </p>
        </div>
        <Button href={link('/contact')} variant="outline">Contact us</Button>
      </div>

      <!-- Content Grid -->
      <div class="grid gap-5 md:grid-cols-2">
        <!-- Mission Card (Full Width) -->
        <Card class="md:col-span-2">
          <Badge variant="secondary">Mission</Badge>
          <p class="mt-3 leading-relaxed text-slate-600">
            <strong class="text-slate-900">Berojgar Engineer</strong> helps CS students learn with confidence through practical explanations, well-structured notes, and articles that stay focused on what matters most.
          </p>
        </Card>

        <!-- Vision Card -->
        <Card>
          <h2 class="text-lg font-semibold text-slate-900 mb-3">
            Our vision
          </h2>
          <p class="leading-relaxed text-slate-600">
            To become the go-to resource for CS students worldwide, with free, high-quality educational content that feels clear and dependable.
          </p>
        </Card>

        <!-- What We Offer Card -->
        <Card>
          <h2 class="text-lg font-semibold text-slate-900 mb-3">
            What we offer
          </h2>
          <ul class="list-disc list-inside space-y-2 leading-relaxed text-slate-600">
            <li>Structured course content for major CS subjects</li>
            <li>Beginner-friendly explanations</li>
            <li>Real-world examples and case studies</li>
            <li>Regular blog posts on industry trends and tips</li>
          </ul>
        </Card>

        <!-- Join Community Card -->
        <Card class="md:col-span-2 flex flex-col gap-4">
          <h2 class="text-lg font-semibold text-slate-900">
            Join the community
          </h2>
          <p class="leading-relaxed text-slate-600">
            Have a topic you'd like us to cover or want to contribute your knowledge? We'd love to hear from you.
          </p>
          <div>
            <Button href={link('/contact')}>Start a conversation</Button>
          </div>
        </Card>
      </div>
    </div>
  </section>
</Base>
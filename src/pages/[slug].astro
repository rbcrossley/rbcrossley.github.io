---
import { getCollection, type CollectionEntry } from 'astro:content';
import Base from '../layouts/Base.astro';
import CourseSidebar from '../components/CourseSidebar.astro';
import DiscoverMore from '../components/DiscoverMore.astro';
import { link } from '../lib/link';
import Button from '../components/ui/Button.astro';
import Card from '../components/ui/Card.astro';
import Badge from '../components/ui/Badge.astro';

export async function getStaticPaths() {
  const courses = await getCollection('courses');
  const topics = await getCollection('topics');
  const paths = [];
  const seen = new Set();

  // Individual topic pages first (a topic can act as the course landing too)
  for (const t of topics) {
    if (seen.has(t.slug)) continue;
    seen.add(t.slug);
    paths.push({
      params: { slug: t.slug },
      props: { type: 'topic', topic: t },
    });
  }

  // Course landing pages for courses that don't already have a matching topic
  for (const course of courses) {
    if (seen.has(course.data.slug)) continue;
    seen.add(course.data.slug);
    paths.push({
      params: { slug: course.data.slug },
      props: { type: 'course', course },
    });
  }

  return paths;
}

const { type } = Astro.props as {
  type: 'topic' | 'course';
  topic?: CollectionEntry<'topics'>;
  course?: CollectionEntry<'courses'>;
};

let course: CollectionEntry<'courses'> | undefined = undefined;
let topic: CollectionEntry<'topics'> | undefined = undefined;
let Content: any;
let currentSlug: string;
let pageTitle: string;
let pageDesc: string;

if (type === 'topic') {
  topic = Astro.props.topic;
  const rendered = await topic.render();
  Content = rendered.Content;
  currentSlug = topic.slug;
  pageTitle = topic.data.title;
  pageDesc = topic.data.description || '';
  const allCourses = await getCollection('courses');
  course = allCourses.find((c: CollectionEntry<'courses'>) => c.data.slug === topic.data.course);
  if (!course) throw new Error(`Course not found for topic ${topic.slug} (course slug: ${topic.data.course})`);
} else {
  course = Astro.props.course;
  if (!course) throw new Error('Course data is missing for static path generation.');
  // Try to render the course landing as a topic too (matching slug)
  const allTopics = await getCollection('topics');
  const landing = allTopics.find((t: CollectionEntry<'topics'>) => t.slug === course.data.slug);
  if (landing) {
    const rendered = await landing.render();
    Content = rendered.Content;
    topic = landing;
    pageTitle = landing.data.title;
    pageDesc = landing.data.description || course.data.description;
  } else {
    pageTitle = course.data.title;
    pageDesc = course.data.description;
  }
  currentSlug = course.data.slug;
}

// Find prev / next within sections
type CourseSection = CollectionEntry<'courses'>['data']['sections'][number];
type CourseTopic = CourseSection['topics'][number];

const sections = course.data.sections as CourseSection[];
const flat: CourseTopic[] = sections.flatMap((section: CourseSection) => section.topics as CourseTopic[]);
const idx = flat.findIndex((topicEntry: CourseTopic) => topicEntry.slug === currentSlug);
const prev = idx > 0 ? flat[idx - 1] : null;
const next = idx >= 0 && idx < flat.length - 1 ? flat[idx + 1] : null;

// Discover more from topic data or fallback (next 3 topics)
let discover = topic?.data?.discoverMore;
if (!discover || discover.length === 0) {
  discover = flat
    .filter((topicEntry: CourseTopic) => topicEntry.slug !== currentSlug)
    .slice(0, 5)
    .map((topicEntry: CourseTopic) => ({ title: topicEntry.title, href: `/${topicEntry.slug}` }));
}
---
<Base title={`${pageTitle} » Berojgar Engineer`} description={pageDesc}>
  <div class="container section-shell mx-auto grid items-start gap-5 lg:grid-cols-[280px_minmax(0,1fr)_280px]">
    <aside class="sticky top-[100px] max-h-[calc(100vh-120px)] overflow-y-auto max-lg:hidden lg:block">
      <Card class="bg-white/92">
        <CourseSidebar course={course.data} currentSlug={currentSlug} />
      </Card>
    </aside>
    <article class="min-w-0">
      <Card>
        <div class="mb-5">
          <Badge variant="secondary">{type === 'topic' ? 'Topic' : 'Course'}</Badge>
          <h1 class="mt-3 text-[clamp(2rem,3vw,2.8rem)] font-bold tracking-tight text-[var(--c-text)]">{pageTitle}</h1>
        </div>
        <div class="prose prose-slate prose-headings:text-[var(--c-text)] prose-a:text-[var(--c-primary)] prose-a:no-underline hover:prose-a:underline prose-blockquote:border-l-[var(--c-primary)] prose-blockquote:bg-[var(--c-primary-light)] prose-code:rounded-md prose-code:bg-[#f3f6fb] prose-code:px-1.5 prose-code:py-0.5 prose-code:before:content-none prose-code:after:content-none prose-img:rounded-xl prose-img:my-4 prose-table:border-collapse prose-th:border prose-th:border-[var(--c-border)] prose-td:border prose-td:border-[var(--c-border)] prose-th:bg-[var(--c-primary-light)] prose-th:px-3 prose-th:py-2 prose-td:px-3 prose-td:py-2 max-w-none">
          {Content ? <Content /> : (
            <p class="text-[var(--c-muted)] italic">{course.data.description}</p>
          )}
        </div>
        <div class="mt-8 flex flex-wrap justify-between gap-4 border-t border-[var(--c-border)] pt-5">
          {prev ? <Button href={link(`/${prev.slug}`)} variant="outline" size="sm">← Previous</Button> : <span></span>}
          {next ? <Button href={link(`/${next.slug}`)} variant="default" size="sm">Next →</Button> : <span></span>}
        </div>
      </Card>
    </article>
    <aside class="sticky top-[100px] max-h-[calc(100vh-120px)] overflow-y-auto max-lg:hidden lg:block">
      <Card class="bg-white/92">
        <DiscoverMore items={discover} />
      </Card>
    </aside>
  </div>
</Base>

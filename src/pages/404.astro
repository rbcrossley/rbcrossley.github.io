---
import Base from '../layouts/Base.astro';
import { link } from '../lib/link';
import Button from '../components/ui/Button.astro';
import Card from '../components/ui/Card.astro';
import Badge from '../components/ui/Badge.astro';
---
<Base title="Page Not Found » Berojgar Engineer">
  <section class="page section-shell py-12 sm:py-14 text-center">
    <div class="container mx-auto max-w-[620px] px-6">
      <Card class="flex flex-col items-center gap-3.5 text-center">
        <Badge variant="secondary">Oops</Badge>
        <h1 class="my-1 text-[clamp(4rem,10vw,6rem)] font-extrabold leading-none text-[var(--c-primary)]">404</h1>
        <h2 class="text-2xl font-semibold text-[var(--c-text)]">Page not found</h2>
        <p class="mt-1 max-w-md leading-[1.75] text-[var(--c-muted)]">The page you're looking for doesn't exist or has been moved.</p>
        <Button href={link('/')}>← Back to home</Button>
      </Card>
    </div>
  </section>
</Base>

---
import Base from '../layouts/Base.astro';
import { link } from '../lib/link';
import Button from '../components/ui/Button.astro';
import Card from '../components/ui/Card.astro';
import Badge from '../components/ui/Badge.astro';
---
<Base title="Page Not Found » Berojgar Engineer">
  <section class="page section-shell">
    <div class="container narrow">
      <Card class="not-found">
        <Badge variant="secondary">Oops</Badge>
        <h1>404</h1>
        <h2>Page not found</h2>
        <p>The page you're looking for doesn't exist or has been moved.</p>
        <Button href={link('/')}>← Back to home</Button>
      </Card>
    </div>
  </section>
</Base>
<style>
  .page { text-align: center; }
  .narrow { max-width: 620px; }
  .not-found {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.85rem;
  }
  h1 { font-size: clamp(4rem, 10vw, 6rem); color: var(--c-primary); line-height: 1; margin: 0.2rem 0; }
  h2 { font-size: 1.5rem; margin: 0; }
  p { color: var(--c-muted); margin: 0.15rem 0 1.1rem; line-height: 1.75; }
</style>

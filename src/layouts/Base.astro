---
import theme from '../../theme.config.js';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title?: string;
  description?: string;
}
const { title = theme.site.name, description = theme.site.tagline } = Astro.props;
const c = theme.colors;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="purpleads-verification" content="94bd49973942f6e2fbea4a99"/>

    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/favicon.svg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=IBM+Plex+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-PR6JJ0FR56"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-PR6JJ0FR56');
    </script>
    <title>{title}</title>
    <style is:global define:vars={{
      'c-primary': c.primary,
      'c-primary-dark': c.primaryDark,
      'c-primary-light': c.primaryLight,
      'c-logo': c.logo,
      'c-hero-bg': c.heroBg,
      'c-hero-text': c.heroText,
      'c-hero-accent': c.heroAccent,
      'c-bg': c.bg,
      'c-text': c.text,
      'c-muted': c.muted,
      'c-card-bg': c.cardBg,
      'c-card-border': c.cardBorder,
      'c-card-hover': c.cardHover,
      'c-sidebar-section': c.sidebarSection,
      'c-sidebar-active': c.sidebarActive,
      'c-sidebar-text': c.sidebarText,
      'c-footer-bg': c.footerBg,
      'c-footer-text': c.footerText,
      'c-border': c.border,
      'font-sans': '"IBM Plex Sans", "Segoe UI", sans-serif',
      'font-display': '"Fraunces", Georgia, serif',
    }}>
      :root { color-scheme: light; }
      * { box-sizing: border-box; }
      html, body { width: 100%; margin: 0; padding: 0; }
      html { height: 100%; }
      body {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        font-family: var(--font-sans);
        background:
          radial-gradient(circle at top left, rgba(15, 61, 120, 0.08), transparent 28%),
          radial-gradient(circle at top right, rgba(11, 36, 71, 0.07), transparent 24%),
          linear-gradient(180deg, #fbfdff 0%, var(--c-bg) 28%, #f3f7fc 100%);
        color: var(--c-text);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }
      main { flex: 1; width: 100%; position: relative; }
      main::before {
        content: '';
        position: fixed;
        inset: 0;
        pointer-events: none;
        background-image: linear-gradient(rgba(15, 23, 42, 0.012) 1px, transparent 1px), linear-gradient(90deg, rgba(15, 23, 42, 0.012) 1px, transparent 1px);
        background-size: 28px 28px;
        mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.18), transparent 35%);
        opacity: 0.6;
      }
      a { color: inherit; }
      img { max-width: 100%; display: block; }
      h1, h2, h3, h4, h5 { font-family: var(--font-display); font-weight: 600; line-height: 1.2; margin: 0; letter-spacing: -0.02em; }
      .container { max-width: 1240px; margin: 0 auto; padding: 0 24px; }
      .section-shell { padding: 72px 0; }
      .eyebrow { color: var(--c-primary); font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; font-size: 0.77rem; }
      .muted { color: var(--c-muted); }
      ::selection { background: var(--c-primary); color: #fff; }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>

---
import theme from '../../theme.config.js';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title?: string;
  description?: string;
}
const { title = theme.site.name, description = theme.site.tagline } = Astro.props;
const c = theme.colors;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL.replace(/\/$/, '')}/favicon.svg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-PR6JJ0FR56"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-PR6JJ0FR56');
    </script>
    <title>{title}</title>
    <style is:global define:vars={{
      'c-primary': c.primary,
      'c-primary-dark': c.primaryDark,
      'c-primary-light': c.primaryLight,
      'c-logo': c.logo,
      'c-hero-bg': c.heroBg,
      'c-hero-text': c.heroText,
      'c-hero-accent': c.heroAccent,
      'c-bg': c.bg,
      'c-text': c.text,
      'c-muted': c.muted,
      'c-card-bg': c.cardBg,
      'c-card-border': c.cardBorder,
      'c-card-hover': c.cardHover,
      'c-sidebar-section': c.sidebarSection,
      'c-sidebar-active': c.sidebarActive,
      'c-sidebar-text': c.sidebarText,
      'c-footer-bg': c.footerBg,
      'c-footer-text': c.footerText,
      'c-border': c.border,
    }}>
      :root { color-scheme: light; }
      * { box-sizing: border-box; }
      html { height: 100%; }
      body {
        margin: 0;
        padding: 0;
        width: 100%;
        height: 100%;
        display: flex;
        flex-direction: column;
        font-family: 'Poppins', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        background: var(--c-bg);
        color: var(--c-text);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }
      main { flex: 1; }
      a { color: inherit; }
      img { max-width: 100%; display: block; }
      h1, h2, h3, h4, h5 { font-family: 'Poppins', sans-serif; font-weight: 700; line-height: 1.25; margin: 0; }
      .container { max-width: 1280px; margin: 0 auto; padding: 0 28px; }
      ::selection { background: var(--c-primary); color: #fff; }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
